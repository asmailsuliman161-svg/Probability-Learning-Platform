<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>منصة إسماعيل لتعليم الاحتمالات</title>

<style>
body {
    font-family: Arial;
    background: linear-gradient(to right,#4facfe,#00f2fe);
    text-align:center;
    margin:0;
}

.container {
    background:white;
    margin:20px auto;
    padding:20px;
    width:360px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,0.2);
}

button {
    padding:10px;
    margin:8px;
    border:none;
    border-radius:10px;
    background:#4CAF50;
    color:white;
    width:80%;
}

input {
    padding:10px;
    width:80%;
    margin:10px;
}

.hidden { display:none; }
</style>
</head>

<body>

<div class="container">

<h2>🎓 منصة إسماعيل للاحتمالات</h2>

<!-- القائمة -->
<div id="menu">
<button onclick="show('lessons')">📘 الدروس</button>
<button onclick="show('videos')">🎥 فيديوهات</button>
<button onclick="show('quiz')">📝 اختبار</button>
<button onclick="show('game')">🎮 لعبة</button>
<button onclick="show('score')">📊 نتائجي</button>
</div>

<!-- الدروس -->
<div id="lessons" class="hidden">
<h3>📘 الدروس</h3>

<button onclick="showLesson('l1')">المفاهيم</button>
<button onclick="showLesson('l2')">الأحداث</button>
<button onclick="showLesson('l3')">العمليات</button>
<button onclick="showLesson('l4')">القوانين</button>

<p id="lessonContent"></p>

<button onclick="show('menu')">رجوع</button>
</div>

<!-- الفيديو -->
<div id="videos" class="hidden">
<h3>🎥 فيديوهات</h3>

<button onclick="loadVideo('https://www.youtube.com/embed/dQw4w9WgXcQ')">فيديو 1</button>
<button onclick="loadVideo('https://www.youtube.com/embed/3JZ_D3ELwOQ')">فيديو 2</button>

<iframe id="videoFrame" width="100%" height="250"></iframe>

<button onclick="show('menu')">رجوع</button>
</div>

<!-- الاختبار -->
<div id="quiz" class="hidden">
<h3>📝 اختبار</h3>

<p id="q"></p>
<input id="ans">
<button onclick="checkQuiz()">تحقق</button>

<p id="quizScore"></p>

<button onclick="show('menu')">رجوع</button>
</div>

<!-- اللعبة -->
<div id="game" class="hidden">
<h3>🎮 لعبة</h3>

<p id="gq"></p>
<input id="gans">
<button onclick="checkGame()">تحقق</button>

<p id="gameScore"></p>

<button onclick="show('menu')">رجوع</button>
</div>

<!-- النتائج -->
<div id="score" class="hidden">
<h3>📊 نتائجي</h3>
<p id="finalScore"></p>
<button onclick="show('menu')">رجوع</button>
</div>

</div>

<script>

// التنقل
function show(id){
document.querySelectorAll(".hidden").forEach(e=>e.style.display="none");
document.getElementById("menu").style.display="none";

if(id=="menu"){
document.getElementById("menu").style.display="block";
}else{
document.getElementById(id).style.display="block";
}
}

// الدروس
function showLesson(id){
let content="";

if(id=="l1"){
content="علم الاحتمال: دراسة النتائج العشوائية\nمثال: حجر نرد";
}
if(id=="l2"){
content="الحدث: جزء من فضاء العينة\nأنواعه: بسيط ومركب";
}
if(id=="l3"){
content="الاتحاد: أو\nالتقاطع: و\nالمتممة: لا";
}
if(id=="l4"){
content="ح(أ)=n(أ)/n(ع)\nح(أ∪ب)=ح(أ)+ح(ب)-ح(أ∩ب)";
}

document.getElementById("lessonContent").innerText = content;
}

// الفيديو
function loadVideo(url){
document.getElementById("videoFrame").src = url;
}

// الاختبار
let quizQ=[
{q:"احتمال عدد زوجي؟",a:"1/2"},
{q:"احتمال أقل من 3؟",a:"1/3"},
{q:"احتمال عدد أولي؟",a:"1/2"}
];

let qi=0,qs=0;

function loadQuiz(){
document.getElementById("q").innerText=quizQ[qi].q;
}

function checkQuiz(){
let u=document.getElementById("ans").value;

if(u==quizQ[qi].a){qs++;}

document.getElementById("quizScore").innerText="النقاط: "+qs;

qi++;
if(qi>=quizQ.length){
localStorage.setItem("quizScore",qs);
alert("انتهى الاختبار: "+qs);
qi=0;qs=0;
}
loadQuiz();
}

// اللعبة
let gameQ=[
{q:"مجموع 7؟",a:"1/6"},
{q:"ورقة قلب؟",a:"1/4"},
{q:"عدد زوجي؟",a:"1/2"}
];

let gi=0,gs=0;

function loadGame(){
document.getElementById("gq").innerText=gameQ[gi].q;
}

function checkGame(){
let u=document.getElementById("gans").value;

if(u==gameQ[gi].a){gs++;}

document.getElementById("gameScore").innerText="النقاط: "+gs;

gi++;
if(gi>=gameQ.length){
localStorage.setItem("gameScore",gs);
alert("انتهت اللعبة: "+gs);
gi=0;gs=0;
}
loadGame();
}

// النتائج
function loadScores(){
let q=localStorage.getItem("quizScore")||0;
let g=localStorage.getItem("gameScore")||0;

document.getElementById("finalScore").innerText=
"الاختبار: "+q+" | اللعبة: "+g;
}

setInterval(loadScores,1000);

// تشغيل
loadQuiz();
loadGame();

</script>

</body>
</html>
