<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>منصة الاحتمالات - النسخة الكاملة</title>

<style>
body {
    font-family: Arial;
    background: linear-gradient(to right,#4facfe,#00f2fe);
    text-align:center;
}

.container {
    background:white;
    margin:20px auto;
    padding:20px;
    width:380px;
    border-radius:20px;
}

button {
    padding:10px;
    margin:6px;
    border:none;
    border-radius:10px;
    background:#4CAF50;
    color:white;
    width:90%;
}

.hidden { display:none; }

input {
    padding:10px;
    width:90%;
}
</style>
</head>

<body>

<div class="container">

<h2>🎓 منصة الاحتمالات</h2>

<div id="menu">
<button onclick="show('lessons')">📘 الدروس</button>
<button onclick="show('exercises')">🧮 التمارين</button>
<button onclick="show('quiz')">📝 اختبار</button>
<button onclick="show('score')">📊 النتائج</button>
</div>

<!-- الدروس -->
<div id="lessons" class="hidden">
<h3>📘 ملخص</h3>
<p>
الاحتمال = الحالات المواتية ÷ الكلية<br><br>
الاتحاد: A ∪ B<br>
التقاطع: A ∩ B<br>
المتممة: A'
</p>
<button onclick="show('menu')">رجوع</button>
</div>

<!-- التمارين -->
<div id="exercises" class="hidden">
<h3>🧮 التمارين</h3>

<p id="exQ"></p>
<input id="exAns" placeholder="اكتب الإجابة">
<br>
<button onclick="checkExercise()">تحقق</button>

<p id="exScore"></p>

<button onclick="nextExercise()">التالي</button>
<br>
<button onclick="show('menu')">رجوع</button>
</div>

<!-- اختبار -->
<div id="quiz" class="hidden">
<h3>📝 اختبار سريع</h3>
<p id="q"></p>
<input id="ans">
<br>
<button onclick="checkQuiz()">تحقق</button>

<p id="quizScore"></p>

<button onclick="show('menu')">رجوع</button>
</div>

<!-- النتائج -->
<div id="score" class="hidden">
<h3>📊 النتائج</h3>
<p id="finalScore"></p>
<button onclick="resetData()">🔄 إعادة تعيين</button>
<button onclick="show('menu')">رجوع</button>
</div>

</div>

<script>

// التنقل
function show(id){
document.querySelectorAll(".hidden").forEach(e=>e.style.display="none");
document.getElementById("menu").style.display="none";

if(id=="menu"){
document.getElementById("menu").style.display="block";
}else{
document.getElementById(id).style.display="block";
}
}

// ================= التمارين (1-5) =================
let exercises=[
{
q:"(1) صندوق به 4 حمراء و6 زرقاء و5 بيضاء. احتمال حمراء؟",
a:"4/15"
},
{
q:"(2) نفس الصندوق. احتمال بيضاء؟",
a:"5/15"
},
{
q:"(3) احتمال حمراء أو زرقاء؟",
a:"10/15"
},
{
q:"(4) اختيار من أوراق الكتشينة: احتمال ورقة قلب؟",
a:"1/4"
},
{
q:"(5) من 20 عدد أولي، احتمال عدد زوجي أو يقبل القسمة على 3؟",
a:""
}
];

let ei = localStorage.getItem("ei") || 0;
let es = localStorage.getItem("es") || 0;

function loadExercise(){
document.getElementById("exQ").innerText = exercises[ei].q;
document.getElementById("exScore").innerText = "النقاط: " + es;
}

function checkExercise(){
let u=document.getElementById("exAns").value;

if(u==exercises[ei].a){
es++;
alert("✔ إجابة صحيحة");
}else{
alert("❌ إجابة خاطئة");
}

localStorage.setItem("es",es);
loadExercise();
}

function nextExercise(){
ei++;
if(ei>=exercises.length){
alert("انتهت التمارين");
ei=0;
}
localStorage.setItem("ei",ei);
loadExercise();
}

// ================= اختبار =================
let quizQ=[
{q:"احتمال عدد زوجي من 1 إلى 6؟",a:"1/2"},
{q:"احتمال عدد أولي؟",a:"1/2"},
{q:"احتمال ظهور رقم 1؟",a:"1/6"}
];

let qi=localStorage.getItem("qi") || 0;
let qs=localStorage.getItem("qs") || 0;

function loadQuiz(){
document.getElementById("q").innerText=quizQ[qi].q;
document.getElementById("quizScore").innerText="النقاط: "+qs;
}

function checkQuiz(){
let u=document.getElementById("ans").value;

if(u==quizQ[qi].a){qs++;}

qi++;
if(qi>=quizQ.length){qi=0;}

localStorage.setItem("qi",qi);
localStorage.setItem("qs",qs);

loadQuiz();
}

// ================= النتائج =================
function loadScores(){
let e=localStorage.getItem("es")||0;
let q=localStorage.getItem("qs")||0;

document.getElementById("finalScore").innerText=
"تمارين: "+e+" | اختبار: "+q;
}

// إعادة تعيين
function resetData(){
localStorage.clear();
location.reload();
}

// تشغيل
loadExercise();
loadQuiz();
setInterval(loadScores,1000);

</script>

</body>
</html>
